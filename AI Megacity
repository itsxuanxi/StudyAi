<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>AI Megacity</title>
  <style>
    * {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
    }

    html, body {
      width: 100%;
      height: 100%;
      overflow: hidden;
      background: #050816;
      font-family: Arial, Helvetica, sans-serif;
    }

    canvas {
      display: block;
      width: 100vw;
      height: 100vh;
    }

    .overlay {
      position: absolute;
      inset: 0;
      pointer-events: none;
      background:
        radial-gradient(circle at 20% 20%, rgba(0,255,255,0.12), transparent 25%),
        radial-gradient(circle at 80% 30%, rgba(255,0,255,0.10), transparent 25%),
        radial-gradient(circle at 50% 90%, rgba(0,140,255,0.10), transparent 30%);
    }

    .title {
      position: absolute;
      top: 28px;
      left: 32px;
      color: white;
      z-index: 10;
      text-shadow: 0 0 20px rgba(0,255,255,0.35);
    }

    .title h1 {
      font-size: 48px;
      letter-spacing: 2px;
      font-weight: 800;
      background: linear-gradient(90deg, #7dd3fc, #c084fc, #22d3ee);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
    }

    .title p {
      margin-top: 10px;
      color: rgba(255,255,255,0.7);
      font-size: 14px;
      letter-spacing: 1px;
    }

    .badge {
      position: absolute;
      right: 28px;
      top: 28px;
      z-index: 10;
      color: rgba(255,255,255,0.85);
      border: 1px solid rgba(255,255,255,0.15);
      background: rgba(255,255,255,0.06);
      backdrop-filter: blur(10px);
      padding: 12px 18px;
      border-radius: 999px;
      font-size: 13px;
      letter-spacing: 1px;
      box-shadow: 0 0 20px rgba(0,255,255,0.08);
    }

    .bottom-info {
      position: absolute;
      left: 32px;
      bottom: 28px;
      z-index: 10;
      color: rgba(255,255,255,0.6);
      font-size: 13px;
      letter-spacing: 1px;
    }
  </style>
</head>
<body>
  <div class="title">
    <h1>AI MEGACITY</h1>
    <p>Autogenerated futuristic skyline • neon towers • drone lanes</p>
  </div>

  <div class="badge">LIVE GENERATIVE CITY</div>
  <div class="bottom-info">Refresh to generate a different city</div>
  <div class="overlay"></div>
  <canvas id="city"></canvas>

  <script>
    const canvas = document.getElementById("city");
    const ctx = canvas.getContext("2d");

    let w = canvas.width = window.innerWidth;
    let h = canvas.height = window.innerHeight;

    const stars = [];
    const drones = [];
    const buildings = [];
    const farBuildings = [];
    const lights = [];

    function rand(min, max) {
      return Math.random() * (max - min) + min;
    }

    function resize() {
      w = canvas.width = window.innerWidth;
      h = canvas.height = window.innerHeight;
      generateCity();
    }

    window.addEventListener("resize", resize);

    function generateStars() {
      stars.length = 0;
      for (let i = 0; i < 160; i++) {
        stars.push({
          x: rand(0, w),
          y: rand(0, h * 0.65),
          r: rand(0.5, 2),
          a: rand(0.2, 1),
          speed: rand(0.002, 0.01)
        });
      }
    }

    function generateBuildings() {
      buildings.length = 0;
      farBuildings.length = 0;
      lights.length = 0;

      let xFar = 0;
      while (xFar < w) {
        const bw = rand(40, 90);
        const bh = rand(h * 0.12, h * 0.35);
        farBuildings.push({
          x: xFar,
          y: h - bh - 120,
          w: bw,
          h: bh,
          hue: rand(190, 280)
        });
        xFar += bw + rand(4, 12);
      }

      let x = 0;
      while (x < w) {
        const bw = rand(55, 120);
        const bh = rand(h * 0.22, h * 0.62);
        const topType = Math.floor(rand(0, 4));
        const hue = rand(180, 320);

        const building = {
          x,
          y: h - bh - 70,
          w: bw,
          h: bh,
          hue,
          topType,
          windows: []
        };

        const cols = Math.max(2, Math.floor(bw / 18));
        const rows = Math.max(4, Math.floor(bh / 22));

        for (let cy = 0; cy < rows; cy++) {
          for (let cx = 0; cx < cols; cx++) {
            if (Math.random() > 0.18) {
              building.windows.push({
                x: x + 10 + cx * ((bw - 20) / cols),
                y: h - bh - 70 + 14 + cy * ((bh - 28) / rows),
                w: rand(4, 8),
                h: rand(8, 14),
                on: Math.random() > 0.25,
                pulse: rand(0, Math.PI * 2)
              });
            }
          }
        }

        if (Math.random() > 0.55) {
          lights.push({
            x: x + bw / 2,
            y: h - bh - 70,
            r: rand(30, 70),
            hue
          });
        }

        buildings.push(building);
        x += bw + rand(6, 16);
      }
    }

    function generateDrones() {
      drones.length = 0;
      for (let i = 0; i < 18; i++) {
        drones.push({
          x: rand(0, w),
          y: rand(h * 0.18, h * 0.58),
          speed: rand(0.8, 2.8),
          size: rand(2, 4),
          trail: []
        });
      }
    }

    function generateCity() {
      generateStars();
      generateBuildings();
      generateDrones();
    }

    function drawSky() {
      const grad = ctx.createLinearGradient(0, 0, 0, h);
      grad.addColorStop(0, "#02030a");
      grad.addColorStop(0.35, "#0b1330");
      grad.addColorStop(0.7, "#111827");
      grad.addColorStop(1, "#050816");
      ctx.fillStyle = grad;
      ctx.fillRect(0, 0, w, h);

      const glow1 = ctx.createRadialGradient(w * 0.2, h * 0.15, 0, w * 0.2, h * 0.15, w * 0.35);
      glow1.addColorStop(0, "rgba(0,255,255,0.12)");
      glow1.addColorStop(1, "rgba(0,255,255,0)");
      ctx.fillStyle = glow1;
      ctx.fillRect(0, 0, w, h);

      const glow2 = ctx.createRadialGradient(w * 0.8, h * 0.22, 0, w * 0.8, h * 0.22, w * 0.28);
      glow2.addColorStop(0, "rgba(255,0,255,0.10)");
      glow2.addColorStop(1, "rgba(255,0,255,0)");
      ctx.fillStyle = glow2;
      ctx.fillRect(0, 0, w, h);
    }

    function drawMoon() {
      const x = w * 0.78;
      const y = h * 0.16;
      const r = Math.min(w, h) * 0.06;

      const g = ctx.createRadialGradient(x, y, 0, x, y, r * 2.5);
      g.addColorStop(0, "rgba(130,240,255,0.20)");
      g.addColorStop(1, "rgba(130,240,255,0)");
      ctx.fillStyle = g;
      ctx.beginPath();
      ctx.arc(x, y, r * 2.5, 0, Math.PI * 2);
      ctx.fill();

      ctx.fillStyle = "rgba(210,250,255,0.85)";
      ctx.beginPath();
      ctx.arc(x, y, r, 0, Math.PI * 2);
      ctx.fill();
    }

    function drawStars(time) {
      for (const s of stars) {
        const alpha = s.a * (0.65 + 0.35 * Math.sin(time * s.speed));
        ctx.fillStyle = `rgba(255,255,255,${alpha})`;
        ctx.beginPath();
        ctx.arc(s.x, s.y, s.r, 0, Math.PI * 2);
        ctx.fill();
      }
    }

    function drawFarBuildings() {
      for (const b of farBuildings) {
        const grad = ctx.createLinearGradient(0, b.y, 0, b.y + b.h);
        grad.addColorStop(0, `hsla(${b.hue}, 70%, 30%, 0.55)`);
        grad.addColorStop(1, "rgba(10,12,26,0.85)");
        ctx.fillStyle = grad;
        ctx.fillRect(b.x, b.y, b.w, b.h);
      }
    }

    function drawMainBuildings(time) {
      for (const b of buildings) {
        const grad = ctx.createLinearGradient(0, b.y, 0, b.y + b.h);
        grad.addColorStop(0, `hsla(${b.hue}, 90%, 60%, 0.22)`);
        grad.addColorStop(0.15, "rgba(30,38,66,0.95)");
        grad.addColorStop(1, "rgba(7,10,20,1)");
        ctx.fillStyle = grad;
        ctx.fillRect(b.x, b.y, b.w, b.h);

        ctx.strokeStyle = "rgba(255,255,255,0.06)";
        ctx.lineWidth = 1;
        ctx.strokeRect(b.x, b.y, b.w, b.h);

        if (b.topType === 0) {
          ctx.strokeStyle = `hsla(${b.hue}, 100%, 70%, 0.9)`;
          ctx.beginPath();
          ctx.moveTo(b.x + b.w / 2, b.y);
          ctx.lineTo(b.x + b.w / 2, b.y - 28);
          ctx.stroke();
        } else if (b.topType === 1) {
          ctx.strokeStyle = `hsla(${b.hue}, 100%, 70%, 0.8)`;
          ctx.beginPath();
          ctx.moveTo(b.x + b.w * 0.25, b.y + 8);
          ctx.lineTo(b.x + b.w * 0.75, b.y + 8);
          ctx.stroke();
        } else if (b.topType === 2) {
          ctx.fillStyle = `hsla(${b.hue}, 100%, 70%, 0.75)`;
          ctx.beginPath();
          ctx.arc(b.x + b.w / 2, b.y + 10, 4, 0, Math.PI * 2);
          ctx.fill();
        }

        for (const win of b.windows) {
          const flicker = 0.75 + 0.25 * Math.sin(time * 0.003 + win.pulse);
          if (win.on) {
            ctx.fillStyle = `rgba(120, 240, 255, ${0.5 * flicker})`;
            ctx.shadowBlur = 8;
            ctx.shadowColor = "rgba(0,255,255,0.35)";
          } else {
            ctx.fillStyle = "rgba(255,255,255,0.06)";
            ctx.shadowBlur = 0;
          }
          ctx.fillRect(win.x, win.y, win.w, win.h);
        }
        ctx.shadowBlur = 0;
      }
    }

    function drawLightGlows() {
      for (const l of lights) {
        const g = ctx.createRadialGradient(l.x, l.y, 0, l.x, l.y, l.r);
        g.addColorStop(0, `hsla(${l.hue}, 100%, 65%, 0.22)`);
        g.addColorStop(1, `hsla(${l.hue}, 100%, 65%, 0)`);
        ctx.fillStyle = g;
        ctx.beginPath();
        ctx.arc(l.x, l.y, l.r, 0, Math.PI * 2);
        ctx.fill();
      }
    }

    function drawGround() {
      const grad = ctx.createLinearGradient(0, h - 110, 0, h);
      grad.addColorStop(0, "rgba(0,180,255,0.08)");
      grad.addColorStop(1, "rgba(0,0,0,0.9)");
      ctx.fillStyle = grad;
      ctx.fillRect(0, h - 110, w, 110);

      ctx.strokeStyle = "rgba(0,255,255,0.18)";
      ctx.lineWidth = 2;
      ctx.beginPath();
      ctx.moveTo(0, h - 72);
      ctx.lineTo(w, h - 72);
      ctx.stroke();

      for (let i = 0; i < w; i += 50) {
        ctx.strokeStyle = "rgba(255,255,255,0.05)";
        ctx.beginPath();
        ctx.moveTo(i, h - 110);
        ctx.lineTo(i + 30, h);
        ctx.stroke();
      }
    }

    function drawDrones() {
      for (const d of drones) {
        d.x += d.speed;
        if (d.x > w + 40) {
          d.x = -40;
          d.y = rand(h * 0.18, h * 0.58);
          d.trail = [];
        }

        d.trail.push({ x: d.x, y: d.y });
        if (d.trail.length > 18) d.trail.shift();

        for (let i = 0; i < d.trail.length; i++) {
          const p = d.trail[i];
          const alpha = i / d.trail.length;
          ctx.fillStyle = `rgba(0,255,255,${alpha * 0.25})`;
          ctx.beginPath();
          ctx.arc(p.x, p.y, d.size * alpha, 0, Math.PI * 2);
          ctx.fill();
        }

        ctx.fillStyle = "rgba(150,255,255,0.95)";
        ctx.shadowBlur = 14;
        ctx.shadowColor = "rgba(0,255,255,0.7)";
        ctx.beginPath();
        ctx.arc(d.x, d.y, d.size, 0, Math.PI * 2);
        ctx.fill();
        ctx.shadowBlur = 0;
      }
    }

    function animate(time) {
      ctx.clearRect(0, 0, w, h);
      drawSky();
      drawMoon();
      drawStars(time);
      drawFarBuildings();
      drawLightGlows();
      drawMainBuildings(time);
      drawGround();
      drawDrones();
      requestAnimationFrame(animate);
    }

    generateCity();
    requestAnimationFrame(animate);
  </script>
</body>
</html>
